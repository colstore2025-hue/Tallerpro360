// api/activarFreemium.js
import admin from "firebase-admin";

// Inicialización de Firebase Admin si no está inicializado
if (!admin.apps.length) {
  admin.initializeApp({
    credential: admin.credential.applicationDefault(), // o tu key JSON
  });
}

export default async function handler(req, res) {
  try {
    // ✅ Solo permitir POST
    if (req.method !== "POST") {
      return res.status(405).json({ ok: false, error: "Método no permitido" });
    }

    const { uid } = req.body;

    if (!uid) {
      return res.status(400).json({ ok: false, error: "UID es requerido" });
    }

    const talleresRef = admin.firestore().collection("talleres").doc(uid);

    const hoy = new Date();
    const vence = new Date();
    vence.setDate(hoy.getDate() + 7);

    await talleresRef.set(
      {
        plan: "freemium",
        estadoPlan: "ACTIVO",
        activadoEn: hoy.toISOString(),
        venceEn: vence.toISOString(),
      },
      { merge: true }
    );

    return res.json({ ok: true, mensaje: "Plan Freemium activado por 7 días", venceEn: vence.toISOString() });
  } catch (error) {
    console.error("Error activando Freemium:", error);
    return res.status(500).json({ ok: false, error: "Error interno del servidor" });
  }
}