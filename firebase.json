{
  "hosting": {
    "public": ".",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/login", "destination": "/login.html" },
      { "source": "/demos", "destination": "/demos/demos/index.html" },
      { "source": "**", "destination": "/index.html" }
    ]
  }
}