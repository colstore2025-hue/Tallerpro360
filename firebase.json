{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [

      { "source": "/login", "destination": "/login.html" },

      { "source": "/app/**", "destination": "/app/index.html" },

      { "source": "/demos", "destination": "/demos/demos/index.html" }

    ]
  }
}