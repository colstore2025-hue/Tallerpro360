{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/home", "destination": "/home.html" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/app", "destination": "/app/index.html" },
    { "source": "/app/(.*)", "destination": "/app/index.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
